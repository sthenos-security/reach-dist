// REACHABLE Security Scan — Jenkinsfile
//
// Declarative pipeline. All stages share the same agent workspace —
// session state lives on disk, no artifact passing between stages.
//
// ── Setup ─────────────────────────────────────────────────────────────
//   1. Create a Pipeline job → Script Path: jenkins/Jenkinsfile
//   2. Optionally set REACHABLE_DIST_REPO, REACHABLE_VERSION, FAIL_THRESHOLD
//      as Jenkins environment variables to override the defaults below.
//
// Exit codes: 0 = clean, 2 = findings above threshold, 1 = scan error

pipeline {

    agent any  // Replace: agent { label 'reach-scanner' }

    options {
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        REACHABLE_DIST_REPO = 'sthenos-security/reach-dist'
        REACHABLE_VERSION   = ''       // leave empty for latest
        FAIL_THRESHOLD      = 'high'   // critical | high | medium | any | none
    }

    stages {

        stage('Install REACHABLE') {
            steps {
                sh '''
                    ARGS=""
                    [ -n "${REACHABLE_VERSION}" ] && ARGS="--version ${REACHABLE_VERSION}"
                    if ! curl -fsSL "https://raw.githubusercontent.com/${REACHABLE_DIST_REPO}/main/install.sh" | bash -s -- $ARGS; then
                        echo "ERROR: install.sh failed"
                        exit 1
                    fi
                    command -v reachctl >/dev/null 2>&1 || { echo "ERROR: reachctl not found after install"; exit 1; }
                    reachctl version
                '''
            }
        }

        stage('Init') {
            steps {
                script {
                    // Capture full output including stderr — needed for diagnostics on failure
                    def raw = sh(
                        script: 'reachctl pipeline init . --json 2>&1',
                        returnStdout: true
                    ).trim()
                    // Extract the JSON line — must not use shell echo with Groovy strings (quoting hazard)
                    def json = raw.split('\n').findAll { it.trim().startsWith('{') }.last() ?: ''
                    if (!json) {
                        echo "ERROR: No JSON from pipeline init. Full output:"
                        echo raw
                        error('pipeline init produced no JSON output')
                    }
                    // Write to file to avoid all shell quoting issues with arbitrary JSON
                    writeFile file: '.reach-init.json', text: json
                    def sessionDir = sh(
                        script: '''python3 - <<'PYEOF'
import sys, json
try:
    with open('.reach-init.json') as f:
        d = json.load(f)
    v = d.get('session_dir', '')
    if not v: raise ValueError('session_dir is empty')
    print(v)
except Exception as e:
    sys.stderr.write('Failed to parse session_dir: ' + str(e) + '\n')
    sys.exit(1)
PYEOF''',
                        returnStdout: true
                    ).trim()
                    if (!sessionDir) error('session_dir is empty after parse')
                    env.SESSION_DIR = sessionDir
                    echo "Session: ${env.SESSION_DIR}"
                }
            }
        }

        stage('Scan') {
            steps {
                sh 'reachctl pipeline step scan --session "$SESSION_DIR"'
            }
        }

        stage('Analyze') {
            parallel {
                stage('Secrets + CWE') {
                    steps { sh 'reachctl pipeline step secrets --session "$SESSION_DIR"' }
                }
                stage('Malware') {
                    steps { sh 'reachctl pipeline step malware --session "$SESSION_DIR"' }
                }
                stage('Package Health') {
                    steps { sh 'reachctl pipeline step health --session "$SESSION_DIR"' }
                }
                stage('IaC') {
                    steps { sh 'reachctl pipeline step iac --session "$SESSION_DIR"' }
                }
                stage('AI/LLM Security') {
                    steps { sh 'reachctl pipeline step ai --session "$SESSION_DIR"' }
                }
                stage('DLP/PII') {
                    steps { sh 'reachctl pipeline step dlp --session "$SESSION_DIR"' }
                }
            }
        }

        stage('Finalize') {
            steps {
                script {
                    def result = sh(
                        script: '''
                            set +e
                            reachctl pipeline finalize --session "$SESSION_DIR" --fail-on "$FAIL_THRESHOLD"
                            echo $?
                        ''',
                        returnStdout: true
                    ).trim()
                    def exitCode = result.split('\n').last().trim()
                    env.FINALIZE_EXIT = exitCode
                    if (exitCode == '2') {
                        unstable("REACHABLE: findings above threshold '${env.FAIL_THRESHOLD}'")
                    } else if (exitCode != '0') {
                        error("REACHABLE: finalize failed (exit ${exitCode})")
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                sh "mkdir -p build/dashboard && find \${HOME}/.reachable/scans -type d -name dashboard -exec cp -r {}/ build/dashboard/ \\; 2>/dev/null || true"
                archiveArtifacts artifacts: 'build/dashboard/**', allowEmptyArchive: true
                sh "find \${HOME}/.reachable/scans -name 'reachable.sarif' -exec cp {} build/ \\; 2>/dev/null || true"
                archiveArtifacts artifacts: 'build/reachable.sarif', allowEmptyArchive: true
                def status = env.FINALIZE_EXIT == '0' ? '✅ Clean'
                           : env.FINALIZE_EXIT == '2' ? '⚠ Findings'
                                                      : '❌ Error'
                currentBuild.description = "${status} | ${env.SESSION_DIR}"
            }
        }
        success  { echo "REACHABLE: clean" }
        unstable { echo "REACHABLE: findings above threshold (${FAIL_THRESHOLD})" }
        failure  { echo "REACHABLE: scan error — check logs" }
    }
}
